profiles:
  fast:
    role: fast
    provider: deepseek
    base_url_env: DEEPSEEK_TEXT_BASE_URL
    api_key_env: DEEPSEEK_TEXT_API_KEY
    model_env: DEEPSEEK_TEXT_MODEL
    endpoint_path: /chat/completions
    input_modalities: [text]
    json_mode: required
    thinking_mode: disabled
    max_output_tokens: 2048
    enabled: true
    priority: 10
    fallback: [local_stub]
    timeout_seconds: 60
    cost_tier: medium
    supports_vision: false
    supports_json: true

  vision:
    role: vision
    provider: volcengine_ark
    base_url_env: VOLCENGINE_VISION_BASE_URL
    api_key_env: VOLCENGINE_VISION_API_KEY
    model_env: VOLCENGINE_VISION_MODEL
    endpoint_path: /chat/completions
    input_modalities: [text, image]
    json_mode: disabled
    image_detail: high
    thinking_mode: provider_default
    max_output_tokens: 2048
    enabled: true
    priority: 10
    fallback: [local_stub]
    timeout_seconds: 90
    cost_tier: medium
    supports_vision: true
    supports_json: false

  ocr:
    role: ocr
    provider: siliconflow
    base_url_env: SILICONFLOW_OCR_BASE_URL
    api_key_env: SILICONFLOW_OCR_API_KEY
    model_env: SILICONFLOW_OCR_MODEL
    endpoint_path: /chat/completions
    input_modalities: [text, image]
    json_mode: disabled
    image_detail: high
    thinking_mode: provider_default
    max_output_tokens: 2048
    enabled: true
    priority: 10
    fallback: [local_ocr_stub, local_stub]
    timeout_seconds: 90
    cost_tier: medium
    supports_vision: true
    supports_json: false
